---
import MainLayout from "../layouts/MainLayout.astro";
import Card from "../components/Card.astro";
import ProjectList from "../components/ProjectList.astro";
import SEO from "../components/SEO.astro";     

---

<MainLayout>
    <!-- Add SEO schema for homepage -->
    <SEO 
        type="person"
        title="Josh Hudson"
        description="Full-Stack Web Developer in Worthing & Brighton | HTML, CSS, JavaScript, PHP, WordPress & Shopify Expert"
        image="https://josh-hudson.co.uk/img/profile.webp"
    />
    <section class="hero">
    <div class="container grid">
      <Card fetchpriority="high" cardClass="sm" image="/img/profile.webp" alt="Profile picture of Josh" />
      <div class="statement">
        <p>
          <accent>Hi, I'm Josh.</accent> I focus on impactful digital
          experiences. I'm a Web Developer who thrives on collaboration,
          transforming ideas into robust web solutions. From the sunny South
          Coast, I craft custom websites and bring innovative projects to life,
          fueled by a passion for code and creativity.
        </p>
      </div>
    </div>
  </section>

  <ProjectList />
</MainLayout>