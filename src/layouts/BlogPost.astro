---
import { Image } from 'astro:assets';
import FormattedDate from '../components/FormattedDate.astro';
import MainLayout from './MainLayout.astro';
import SEO from "../components/SEO.astro";


const { title, description, pubDate, updatedDate, heroImage, relatedPosts } = Astro.props;

// JSON-LD article schema
 const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
    headline: title,
    description: description,
    image: heroImage ? new URL(heroImage.src, Astro.site).toString() : undefined,
    datePublished: pubDate.toISOString(),
    dateModified: updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
    author: {
        '@type': 'Person',
        name: 'Josh Hudson',
        url: 'https://josh-hudson.co.uk',
    },
    publisher: {
        '@type': 'Organization',
        name: 'Josh Hudson',
        logo: {
            '@type': 'ImageObject',
            url: 'https://josh-hudson.co.uk/logo.svg',
        },
    },
 }


---

<MainLayout title={title} description={description}>
	    <!-- Add SEO schema here -->
    <SEO 
        type="article"
        title={title}
        description={description}
        image={heroImage ? new URL(heroImage.src, Astro.site).toString() : undefined}
        datePublished={pubDate}
        dateModified={updatedDate}
        author={{ name: 'Josh Hudson', url: 'https://josh-hudson.co.uk' }}
    />

	    <!-- Add this in the head -->
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    </Fragment>
	<article>
		<div class="prose container">
			<slot />
		</div>


		<section class="related-posts">
			<div class="container">
			<h2>Read more...</h2>
			<div class="blog-grid">
			<div class="blog-cards">
				{relatedPosts.map((post) => (
						<div
							class="blog-card"
							data-tags={(post.data.tags ?? []).map((t) => t.toLowerCase()).join(',')}
						>
							<a href={`/blog/${post.id}/`}>
								<div class="blog-card-rollover"></div>
								<div class="blog-card-content">
									<h4>{post.data.title}</h4>
									<p class="blog-card-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									{post.data.tags && post.data.tags.length > 0 && (
										<ul class="blog-card-tags">
											{post.data.tags.map((tag) => (
												<li class="blog-tag">{tag}</li>
											))}
										</ul>
									)}
								</div>
							</a>
						</div>
				))}
			</div>
			</div>
			</div>
		</section>

		<div class="post-header">
			<div class="container grid">
				{heroImage && (
					<div class="blog-header-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="blog-header-content">
					<div>
						<div class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<div class="last-updated-on">
									Last updated on <FormattedDate date={updatedDate} />
								</div>
							)}
													{Astro.props.tags && (
							<div class="tags">
								{Astro.props.tags.map((tag: string) => (
									<span class="blog-tag">{tag}</span>
								))}
							</div>
						)}
						</div>

						<h1>{title}</h1>
					</div>
				</div>
			</div>
		</div>
	</article>	
</MainLayout>
